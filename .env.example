NODE_ENV=development
APP_NAME=Portfolio AI Representative
APP_BASE_URL=http://localhost:3000

# Provider config
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2

# Database config
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio_ai

# Feature flags
ENABLE_DB=true
ENABLE_LLM=true
ENABLE_VERBOSE_LOGS=true
CHAT_TOP_K=5
RETRIEVAL_MIN_SCORE=4
